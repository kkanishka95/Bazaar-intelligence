# Bazaar Intelligence Environment Variables
# Copy this file to .env and fill in values
# Never commit .env to git

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: for future WhatsApp automation
KALEYRA_API_KEY=
KALEYRA_SID=
WHATSAPP_TARGET_NUMBERS=+91XXXXXXXXXX,+91XXXXXXXXXX

# GitHub (for PR creation in quarterly reviews)
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=your-username/bazaar-intelligence
